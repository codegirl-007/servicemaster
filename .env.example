# Application
APP_ENV=development
HTTP_ADDR=:8080

# Local Postgres
# Matches a typical local Docker Postgres setup:
# user: servicemaster
# password: servicemaster
# database: servicemaster_dev
# host: localhost
# port: 5432
DATABASE_URL=postgres://servicemaster:servicemaster@localhost:5432/servicemaster_dev?sslmode=disable

# Database connection pool
DATABASE_MAX_OPEN_CONNS=10
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=30m
DATABASE_CONN_MAX_IDLE_TIME=5m

TOKEN_ENCRYPTION_KEY_BASE64=

# Integration / API Keys
GOOGLE_MAPS_API_KEY=

# QuickBooks Online OAuth
# Register an app at https://developer.intuit.com to get a client ID and secret.
# The redirect URI must match exactly what is configured in the Intuit developer portal.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:8080/qbo/callback
QBO_SCOPES=com.intuit.quickbooks.accounting

# Temporary tenant identifier until user auth exists
DEFAULT_TENANT_ID=
